# ─── nCore bejelentkezés ────────────────────────────────────────
NCORE_USER=your_ncore_username
NCORE_PASS=your_ncore_password

# ─── Debrid-Link API ────────────────────────────────────────────
# API kulcs szerzése: https://debrid-link.com/api_doc/v2/
DEBRID_API_KEY=your_debrid_link_api_key

# ─── Szerver ────────────────────────────────────────────────────
PORT=7000

# ─── Publikus elérés (opcionális, HTTPS-hez) ──────────────────
# A teljes publikus URL a token útvonallal együtt.
# Pl: https://ncore-stremio.duckdns.org/BarackFa789
# Ha nincs beállítva, a /play végpont relatív URL-eket használ.
PUBLIC_URL=https://your-domain.com/your-token
